{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "Multi-platform Pomodoro Timer - Web, Desktop & Mobile",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:clean": "rimraf dist && npm run build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "rimraf dist release && npm run build && electron-builder",
    "electron:build:copy": "npm run build && electron-builder && node scripts/copy-builds.js",
    "build:all": "rimraf dist release && npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.17.4",
    "wait-on": "^7.2.0"
  }
}
